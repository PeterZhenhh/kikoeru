{
  "name": "unikikoeru",
  "type": "module",
  "scripts": {
    "dev-workers": "wrangler dev --config wrangler_workers.jsonc",
    "dev-pages": "wrangler pages dev",
    "dev-deno": "deno run --watch --allow-net --allow-env --allow-read --allow-sys --unstable-sloppy-imports src/entrypoint/index_deno.ts",
    "dev-eo": "yarn build-eo && edgeone pages dev",
    "dev-node": "tsx src/entrypoint/index_node.ts",
    "dev-bun": "bun run --hot src/entrypoint/index_bun.ts",
    "dev-vc": "yarn build-vc && vc dev --listen 8080",
    "dev-wasm": "vite build && wasmer run . --net",
    "dev-fastly": "npx @fastly/compute-js-static-publish publish-content --local && fastly compute serve --addr 0.0.0.0:8080",
    "dev-ntl": "netlify build && netlify dev",
    "dev-esa": "yarn build-esa && deno serve --allow-net --allow-env --allow-read --allow-sys --unstable-sloppy-imports --port 8080 dist/index.js",
    "preview-vc": "yarn build-vc && bun run --hot dist/index.js",
    "build-deno": "vite build --config vite.config.deno.ts",
    "build-vc": "vite build --config vite.config.vercel.ts",
    "build-wasm": "vite build --config vite.config.wasm.ts",
    "build-fastly-esbuild": "esbuild --bundle ./src/entrypoint/index_fastly.ts --outdir=dist --platform=neutral --external:fastly:* --external:node:* --external:jsonata --external:hono/bun --external:hono/deno && js-compute-runtime ./dist/index_fastly.js ./bin/main.wasm",
    "build-fastly": "vite build --config vite.config.fastly.ts && js-compute-runtime ./dist/index.js ./bin/main.wasm",
    "build-ntl": "vite build --config vite.config.ntl.ts",
    "build-fastedge": "npx fastedge-assets ./public src/public-static-assets.ts && node -e \"const fs=require('fs');let s=fs.readFileSync('src/public-static-assets.ts','utf8');fs.writeFileSync('src/public-static-assets.ts',s.replace(/\\\\/g,'/'))\" && npx fastedge-build --input ./src/entrypoint/index.fastedge.ts --output ./wasm/basic-http.wasm && node -e \"require('fs').unlinkSync('src/public-static-assets.ts')\"",
    "build-eo": "vite build --config vite.config.eo.ts",
    "build-esa": "vite build --config vite.config.esa.ts",
    "build-esa-esbuild": "esbuild --bundle ./src/entrypoint/index_esa.ts --outfile=./dist/index.js --platform=neutral --external:fastly:* --external:node:* --external:jsonata --external:hono/bun --external:hono/deno --external:subsrt-ts --define:__wsRuntime__=\\\"deno\\\"",
    "deploy-deno": "",
    "deploy-fly": "flyctl deploy --remote-only",
    "deploy-vc": "vc deploy --prod",
    "deploy-wasm": "yarn build-wasm && wasmer deploy",
    "deploy-fastly": "fastly compute publish && npx @fastly/compute-js-static-publish clean --fastly-api-token=xxx && npx @fastly/compute-js-static-publish publish-content --fastly-api-token=xxx",
    "deploy-ntl": "netlify deploy",
    "type-check": "tsc"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@hono/zod-validator": "^0.8.0",
    "@sentry/bun": "^10.47.0",
    "bigint-buffer": "^1.1.5",
    "cheerio": "^1.2.0",
    "edgeone": "^1.4.2",
    "hono": "^4.12.12",
    "subsrt-ts": "^2.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260408.1",
    "@edgeone/ef-types": "^1.0.5",
    "@fastly/cli": "^14.2.0",
    "@gcoredev/fastedge-sdk-js": "^2.2.0",
    "@hono/vite-build": "^1.11.1",
    "@netlify/edge-functions": "^3.0.6",
    "@types/bun": "^1.3.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.2",
    "bun": "^1.3.11",
    "deno": "^2.7.11",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vercel": "^54.14.1",
    "vite": "^8.0.7",
    "wrangler": "^4.81.0"
  },
  "packageManager": "yarn@1.22.22"
}
